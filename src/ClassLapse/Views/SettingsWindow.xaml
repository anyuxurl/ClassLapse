<Window x:Class="ClassLapse.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClassLapse 设置"
        Width="680" Height="600"
        MinWidth="540" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- 首次运行 banner（默认隐藏，构造器控制） -->
        <Border x:Name="FirstRunBanner" DockPanel.Dock="Top"
                Background="#FFF8E1" BorderBrush="#F0C419" BorderThickness="0,0,0,1"
                Padding="16,12" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="👋 欢迎使用 ClassLapse · 课堂延时"
                           FontSize="15" FontWeight="SemiBold" Foreground="#664D03"/>
                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#806230"
                           Text="第一次启动，请把下面 3 个 Tab 都过一遍：选摄像头（避开展台）→ 选输出文件夹 → 调整拍照计划。完成后点&quot;确定&quot;开始工作。"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#666"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="OkButton" Content="确定" Width="88" Height="28" Margin="6,0"
                            Click="OnSaveClick" IsDefault="True"/>
                    <Button x:Name="CancelButton" Content="取消" Width="88" Height="28" Margin="6,0,0,0"
                            Click="OnCancelClick" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Margin="12">

            <!-- ============ Tab 1: 拍照计划 ============ -->
            <TabItem Header="拍照计划">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <TextBlock Style="{StaticResource HintText}"
                                   Text="每个条目独立配置：模式（间隔/定时）、生效星期、时段或时间点。条目之间允许时间重叠。"/>

                        <StackPanel x:Name="EntriesPanel" Margin="0,4,0,0"/>

                        <Button x:Name="AddEntryButton" Content="+ 添加条目" Width="120" HorizontalAlignment="Left"
                                Margin="0,10,0,0" Click="OnAddEntryClick"/>

                        <Border Margin="0,18,0,0" Padding="12" Background="#F5F8FA" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="预计拍摄量" FontWeight="SemiBold"/>
                                <TextBlock x:Name="EstimateText" Margin="0,4,0,0" Foreground="#444" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ Tab 2: 摄像头 ============ -->
            <TabItem Header="摄像头">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <Label Content="选择摄像头"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="CameraCombo" Width="380" DisplayMemberPath="FriendlyName"/>
                            <Button Content="刷新" Width="64" Margin="8,0,0,0" Click="OnRefreshCamerasClick"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="提示：避开老师上课会用的展台、希沃自带相机等设备"/>

                        <CheckBox x:Name="HighestResCheck" Content="使用设备最高分辨率（推荐 — 画质最佳）"
                                  Margin="0,16,0,0" Click="OnHighestResToggle"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="勾选后忽略下面的目标分辨率，按摄像头能输出的最大分辨率拍摄"/>

                        <Label Content="目标分辨率（仅在未勾选&quot;最高分辨率&quot;时生效）"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="WidthBox" Width="80"/>
                            <TextBlock Text="  ×  " VerticalAlignment="Center"/>
                            <TextBox x:Name="HeightBox" Width="80"/>
                            <TextBlock Text="   (实际会选最接近的支持值)" VerticalAlignment="Center" Foreground="#888"/>
                        </StackPanel>

                        <Label Content="JPEG 质量 (1-100，越大越清晰但体积越大)"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="QualitySlider" Width="320" Minimum="1" Maximum="100"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ValueChanged="OnQualityChanged"/>
                            <TextBox x:Name="QualityBox" Width="60" Margin="12,0,0,0"
                                     TextChanged="OnQualityBoxChanged"/>
                        </StackPanel>

                        <Button Content="📷  用当前摄像头拍一张测试" Width="280" Height="32"
                                Margin="0,16,0,0" HorizontalAlignment="Left"
                                Click="OnTestCaptureClick"/>
                        <TextBlock x:Name="CameraTestResult" Margin="0,8,0,0" Foreground="#444"
                                   TextWrapping="Wrap"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ Tab 3: 水印 ============ -->
            <TabItem Header="水印">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <CheckBox x:Name="WatermarkEnableCheck" Content="在每张照片上烧入时间戳水印"
                                  Click="OnWatermarkOptionChanged"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="拍照时把时间直接画进照片（不可逆）；合成的延时视频会显示时间推进。"/>

                        <Label Content="位置"/>
                        <ComboBox x:Name="WatermarkPositionCombo" Width="160" HorizontalAlignment="Left"
                                  VerticalContentAlignment="Center" SelectionChanged="OnWatermarkOptionChanged"/>

                        <Label Content="时间格式"/>
                        <TextBox x:Name="WatermarkFormatBox" Width="260" HorizontalAlignment="Left"
                                 TextChanged="OnWatermarkOptionChanged"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="如 yyyy-MM-dd HH:mm:ss、HH:mm、yyyy/MM/dd dddd（格式无效会自动回退）"/>

                        <Label Content="字号（像素，0 = 自动按分辨率）"/>
                        <TextBox x:Name="WatermarkFontSizeBox" Width="80" HorizontalAlignment="Left"
                                 TextChanged="OnWatermarkOptionChanged"/>

                        <Label Content="颜色（hex，如 #FFFFFF）"/>
                        <TextBox x:Name="WatermarkColorBox" Width="120" HorizontalAlignment="Left"
                                 TextChanged="OnWatermarkOptionChanged"/>

                        <CheckBox x:Name="WatermarkOutlineCheck" Content="深色描边（任意背景都清晰）"
                                  Margin="0,14,0,0" Click="OnWatermarkOptionChanged"/>

                        <Label Content="预览"/>
                        <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="4"
                                HorizontalAlignment="Left" Background="#FAFAFA">
                            <Image x:Name="WatermarkPreview" Width="384" Height="216" Stretch="Uniform"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ Tab 4: 存储 ============ -->
            <TabItem Header="存储">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <Label Content="输出文件夹"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="OutputFolderBox" Width="480"/>
                            <Button Content="浏览..." Width="80" Margin="8,0,0,0"
                                    Click="OnBrowseFolderClick"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="照片按日期归档：{输出文件夹}/2026-05-17/14-30-00.jpg"/>

                        <CheckBox x:Name="AutoCleanupCheck" Content="启用自动清理（默认关闭）"
                                  Margin="0,18,0,0" Click="OnAutoCleanupToggle"/>

                        <Grid Margin="24,4,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="保留最近"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="CleanupDaysBox" Width="60"/>
                                <TextBlock Text="   天，更早的自动删除" VerticalAlignment="Center" Foreground="#888"/>
                            </StackPanel>

                            <Label Grid.Row="1" Grid.Column="0" Content="磁盘上限"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="MaxDiskBox" Width="60"/>
                                <TextBlock Text="   GB（0 = 不限）" VerticalAlignment="Center" Foreground="#888"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ Tab 5: 关于 ============ -->
            <TabItem Header="关于">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <TextBlock Text="ClassLapse · 课堂延时" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock x:Name="VersionText" Margin="0,2,0,12" Foreground="#666"/>
                        <TextBlock Text="希沃白板自动拍照工具，按计划用指定摄像头拍照存盘，方便后期合成延时视频。"
                                   TextWrapping="Wrap" Foreground="#444"/>

                        <Separator Margin="0,16"/>

                        <CheckBox x:Name="AutoStartCheck" Content="开机自动启动 (HKCU\Run)"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="勾选后将在 HKCU\Software\Microsoft\Windows\CurrentVersion\Run 写入当前 exe 路径。无需管理员权限。"/>

                        <Separator Margin="0,16"/>

                        <Label Content="配置文件"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="ConfigPathBox" Width="440" IsReadOnly="True"/>
                            <Button Content="打开" Width="80" Margin="8,0,0,0" Click="OnOpenConfigClick"/>
                        </StackPanel>

                        <Label Content="日志目录"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="LogDirBox" Width="440" IsReadOnly="True"/>
                            <Button Content="打开" Width="80" Margin="8,0,0,0" Click="OnOpenLogsClick"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
