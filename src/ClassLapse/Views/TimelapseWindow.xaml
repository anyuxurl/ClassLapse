<Window x:Class="ClassLapse.Views.TimelapseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="合成延时视频"
        Width="640" Height="600"
        MinWidth="540" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- bottom bar: status + progress + actions -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#666"
                           TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ProgressBar x:Name="Progress" Width="150" Height="16" Margin="0,0,10,0"
                                 VerticalAlignment="Center" Minimum="0" Maximum="100" Visibility="Collapsed"/>
                    <Button x:Name="ComposeButton" Content="开始合成" Width="96" Height="28" Margin="2,0"
                            Click="OnComposeClick" IsDefault="True"/>
                    <Button x:Name="CancelComposeButton" Content="取消" Width="72" Height="28" Margin="2,0,0,0"
                            Click="OnCancelComposeClick" Visibility="Collapsed"/>
                    <Button x:Name="OpenResultButton" Content="打开" Width="72" Height="28" Margin="2,0,0,0"
                            Click="OnOpenResultClick" Visibility="Collapsed"/>
                    <Button x:Name="CloseButton" Content="关闭" Width="72" Height="28" Margin="2,0,0,0"
                            Click="OnCloseClick" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ffmpeg status -->
            <Border Grid.Row="0" Background="#F5F8FA" Padding="12,8" CornerRadius="4">
                <DockPanel>
                    <Button x:Name="PickFfmpegButton" DockPanel.Dock="Right" Content="选择 ffmpeg.exe"
                            Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center" Click="OnPickFfmpegClick"/>
                    <TextBlock x:Name="FfmpegStatus" VerticalAlignment="Center" TextWrapping="Wrap"
                               Text="正在检测 ffmpeg..."/>
                </DockPanel>
            </Border>

            <!-- days header -->
            <DockPanel Grid.Row="1" Margin="0,14,0,4">
                <TextBlock Text="选择要合成的日期" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="全选" Padding="8,2" Margin="0,0,6,0" Click="OnSelectAllClick"/>
                    <Button Content="清空" Padding="8,2" Click="OnSelectNoneClick"/>
                </StackPanel>
            </DockPanel>

            <!-- day list -->
            <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DaysPanel" Margin="10,8"/>
                </ScrollViewer>
            </Border>

            <!-- options -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="帧率" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBox x:Name="FpsBox" Width="56" TextChanged="OnOptionChanged"/>
                    <TextBlock Text=" 帧/秒" VerticalAlignment="Center" Foreground="#888"/>
                </StackPanel>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="分辨率" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="ResolutionCombo" Grid.Row="0" Grid.Column="3" Width="170"
                          VerticalContentAlignment="Center" SelectionChanged="OnOptionChanged"/>

                <CheckBox x:Name="BrightnessCheck" Grid.Row="0" Grid.Column="4" Content="亮度统一"
                          VerticalAlignment="Center" HorizontalAlignment="Left" Margin="16,0,0,0" IsEnabled="False"
                          ToolTip="消除画面忽明忽暗（webcam 自动曝光、开关灯、投影仪、天光变化）。时间窗平滑，保留白天→傍晚的缓慢明暗变化。"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="节奏" VerticalAlignment="Center" Margin="0,10,6,0"/>
                <ComboBox x:Name="PaceCombo" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,10,0,0"
                          HorizontalAlignment="Left" MinWidth="260"
                          VerticalContentAlignment="Center" SelectionChanged="OnOptionChanged"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="输出" VerticalAlignment="Center" Margin="0,10,6,0"/>
                <TextBox x:Name="OutputBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,10,0,0"
                         TextChanged="OnOutputManuallyEdited"/>
                <Button Grid.Row="2" Grid.Column="4" Content="另存为..." Padding="8,2" Margin="8,10,0,0"
                        Click="OnBrowseOutputClick"/>
            </Grid>

            <!-- estimate -->
            <TextBlock x:Name="EstimateText" Grid.Row="4" Style="{StaticResource HintText}" Margin="0,10,0,0"
                       TextWrapping="Wrap"/>
        </Grid>
    </DockPanel>
</Window>
